# SciAi-Nova OS Environment Configuration
# Docker Compose loads this file into backend + celery-worker (env_file: .env).
# Service hostnames in docker-compose.yml override localhost values below.

# Database (Postgres required in production)
DATABASE_URL=postgresql://scinova:scinova@localhost:5432/scinova
SQLITE_FALLBACK=false

# Security — change before deploying
SECRET_KEY=scinova-dev-secret-change-in-production

# Redis + Celery (async ingestion)
REDIS_URL=redis://localhost:6379/0
USE_CELERY=true

# File Storage
UPLOAD_DIR=./storage/uploads

# Frontier LLM — OpenAI (direct API) and/or Anthropic Claude (via Bedrock)
# Set LLM_MODEL to a gpt-* id for OpenAI, or anthropic.* for Bedrock Claude.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Bedrock Claude (pick the id IT enabled — must be uncommented, not OpenAI gpt-*):
# LLM_MODEL=global.anthropic.claude-sonnet-4-6
# LLM_MODEL=global.anthropic.claude-sonnet-4-6-v1:0
# LLM_MODEL=us.anthropic.claude-sonnet-4-6-v1:0
# LLM_FALLBACK_MODEL=gpt-4o-mini

# Embeddings: auto (OpenAI first, else Bedrock) | openai | bedrock
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=text-embedding-3-small
# On AWS EC2 with Bedrock only: EMBEDDING_PROVIDER=bedrock
# Smoke test: ./scripts/test-bedrock.sh

# Amazon Bedrock — embeddings (Titan/Cohere) + Anthropic Claude LLM
# On EC2, leave AWS keys empty and attach an IAM role with bedrock:InvokeModel
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# Text embeddings for RAG (NOT titan-embed-image — that is for images only)
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
# BEDROCK_EMBEDDING_MODEL=us.amazon.titan-embed-text-v2:0
# BEDROCK_EMBEDDING_MODEL=cohere.embed-english-v3
# Bedrock Claude inference profile (match LLM_MODEL):
# BEDROCK_LLM_MODEL=global.anthropic.claude-sonnet-4-6
BEDROCK_LLM_MODEL=us.anthropic.claude-sonnet-4-6-v1:0
LLM_MAX_TOKENS=4096

# SLM Provider (Mistral) — Ministral 8B for all SLM-routed agent tasks
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_BASE_URL=https://api.mistral.ai/v1
SLM_MODEL=ministral-8b-latest

# Neo4j Graph DB (required)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scinova12
NEO4J_ENABLED=true

# Vector DB (ChromaDB)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_USE_HTTP=false
ANONYMIZED_TELEMETRY=FALSE

# Data Fabric
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# CORS (set to your Railway frontend URL in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Per-user quotas (admin role bypasses limits)
QUOTA_MAX_UPLOADS=2
QUOTA_MAX_WORKFLOWS=2

# Production
ENVIRONMENT=development
